DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erp_paisagismo?schema=public"
PORT=3333
# Segredo para assinar os JWT. Só dev local — em produção, gerar um valor
# aleatório longo e mantê-lo fora do controle de versão.
JWT_SECRET="dev-local-erp-paisagismo-troque-em-producao"
# ⚠️ TEMPORÁRIO (fase de testes): desativa a exigência de login — todo acesso
# entra como ADMIN de teste. Para reativar o login normal, remova esta linha
# (ou mude para "true") e reinicie o servidor.
AUTH_ENABLED=false
